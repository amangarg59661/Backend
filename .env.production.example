# ============================================================================
# Production environment. Copy to .env on the prod host and edit.
#   cp .env.production.example .env
#
# Hard security defaults live in application-prod.yml — this file only wires
# secrets and provider endpoints. Every value below MUST be set.
# ============================================================================

SPRING_PROFILES_ACTIVE=prod

# --- Database (Supabase prod project) ---------------------------------------
DB_PROVIDER=supabase
DB_URL=jdbc:postgresql://db.<prod-project-ref>.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=<supabase-prod-db-password>

# --- Redis (required for multi-instance in prod) ----------------------------
REDIS_ENABLED=true
REDIS_HOST=<redis-host>
REDIS_PORT=6379
REDIS_PASSWORD=<redis-password>

# --- Mail (Resend transactional) --------------------------------------------
# Get API key from https://resend.com/api-keys. Username is literally "resend".
MAIL_PROVIDER=resend
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
RESEND_API_KEY=re_<your-resend-api-key>
MAIL_FROM=no-reply@<your-verified-domain>

# --- Sentry (required in prod) ----------------------------------------------
SENTRY_ENABLED=true
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=self-backend@<git-sha>
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- JWT (rotate on every deploy; 256-bit random) ---------------------------
JWT_SECRET=<32-byte-random-secret>
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P30D

# --- Secret encryption (base64 32 bytes) -----------------------------------
# Generate: openssl rand -base64 32
# Rotating this key invalidates every stored TOTP secret + trusted device.
SECRET_ENCRYPTION_KEY=<base64-32-bytes>

# --- Auth self-service extras -----------------------------------------------
AUTH_TWO_FACTOR_ENROLLMENT=true
AUTH_REMEMBER_DEVICE_DAYS=30

# --- File storage backend (supabase | s3) -----------------------------------
FILE_BACKEND=supabase

# --- Payments ---------------------------------------------------------------
PAYMENTS_STRIPE_ENABLED=true
PAYMENTS_RAZORPAY_ENABLED=true
PAYMENTS_MANUAL_ENABLED=true

STRIPE_SECRET_KEY=sk_live_<stripe-secret>
STRIPE_WEBHOOK_SECRET=whsec_<stripe-webhook-signing-secret>

RAZORPAY_KEY_ID=rzp_live_<key-id>
RAZORPAY_KEY_SECRET=<razorpay-secret>
RAZORPAY_WEBHOOK_SECRET=<razorpay-webhook-secret>

# --- Notification channels --------------------------------------------------
NOTIFICATIONS_EMAIL=true
NOTIFICATIONS_IN_APP=true
NOTIFICATIONS_WHATSAPP=true
NOTIFICATIONS_SMS=false

# --- Calendar + messaging ---------------------------------------------------
CALENDAR_PROVIDER=calcom
GOOGLE_CALENDAR_SYNC=true
WHATSAPP_ENABLED=true

# --- Seed admin (leave blank in prod — provision via runbook, not env) ------
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- CORS (required — no default; deployment fails without it) --------------
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

# --- Rate limit (tighten via env if abuse detected) -------------------------
RATE_LIMIT_EMAIL=5
RATE_LIMIT_IP=20

# --- Server -----------------------------------------------------------------
SERVER_PORT=8080
