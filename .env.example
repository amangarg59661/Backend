# ============================================================================
# EDSS backend environment. Copy to .env and edit.
#
# All app behavior toggled via edss.features.* in application.yml. Env vars
# below override those defaults. Add new flags to FeaturesProperties.java and
# reference them here.
# ============================================================================

# ----------------------------------------------------------------------------
# Database — driver is always Postgres. DB_PROVIDER is a documentation tag
# that flows into logs and metrics; DB_URL is what actually connects.
# ----------------------------------------------------------------------------
DB_PROVIDER=local
DB_URL=jdbc:postgresql://localhost:5433/edss
DB_USERNAME=edss
DB_PASSWORD=edss

# --- Supabase (paste from Project Settings > Database > Connection String) --
# DB_PROVIDER=supabase
# DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# DB_USERNAME=postgres
# DB_PASSWORD=<supabase-db-password>

# --- Neon (paste from Neon Console > Connection Details, JDBC form) ---------
# DB_PROVIDER=neon
# DB_URL=jdbc:postgresql://<host>.neon.tech/<db>?sslmode=require
# DB_USERNAME=<neon-user>
# DB_PASSWORD=<neon-password>

# ----------------------------------------------------------------------------
# Redis — off by default. Flip to true when scaling to multiple instances or
# when durable refresh tokens / cross-instance rate limits are needed.
# ----------------------------------------------------------------------------
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------------------------------------------------------
# Auth feature flags
# ----------------------------------------------------------------------------
AUTH_TWO_FACTOR=false
AUTH_RATE_LIMIT=true
AUTH_PASSWORD_RESET=true
AUTH_SESSION_ROTATION=true

# ----------------------------------------------------------------------------
# Outbox relay — event bus on/off. Turn off for data-import migrations.
# ----------------------------------------------------------------------------
OUTBOX_RELAY=true

# ----------------------------------------------------------------------------
# Convex integration — projection store only, Postgres stays authoritative.
# Not wired to any module yet.
# ----------------------------------------------------------------------------
CONVEX_ENABLED=false
CONVEX_URL=
CONVEX_DEPLOY_KEY=

# ----------------------------------------------------------------------------
# JWT (must be >= 32 bytes / 256 bits)
# ----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-32-byte-random-secret-value-please
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P30D

# ----------------------------------------------------------------------------
# Mail (mailhog for local dev)
# ----------------------------------------------------------------------------
MAIL_PROVIDER=mailhog
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@edss.local

# ----------------------------------------------------------------------------
# Seed admin (dev only)
# ----------------------------------------------------------------------------
ADMIN_EMAIL=admin@edss.local
ADMIN_PASSWORD=Admin@Password123!

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
SERVER_PORT=8080
