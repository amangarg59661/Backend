# Database
DB_URL=jdbc:postgresql://localhost:5432/edss
DB_USERNAME=edss
DB_PASSWORD=edss

# Redis — off by default. Set true when scaling out to multiple instances or
# when durable refresh tokens / cross-instance rate limits are needed.
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (must be >= 32 bytes / 256 bits)
JWT_SECRET=change-me-to-a-32-byte-random-secret-value-please
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P30D

# Mail (defaults to Mailhog in docker-compose)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@edss.local

# Seed admin (dev only)
ADMIN_EMAIL=admin@edss.local
ADMIN_PASSWORD=Admin@Password123!

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# Server
SERVER_PORT=8080
