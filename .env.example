# ============================================================================
# EDSS backend environment. Copy to .env and edit.
#
# All app behavior toggled via edss.features.* in application.yml. Env vars
# below override those defaults. Add new flags to FeaturesProperties.java and
# reference them here.
# ============================================================================

# ----------------------------------------------------------------------------
# Database — driver is always Postgres. Only Supabase (managed) and a future
# self-hosted Postgres are supported. DB_PROVIDER is a documentation tag
# surfaced in logs; DB_URL is what actually connects.
# ----------------------------------------------------------------------------

# --- Supabase (paste from Project Settings > Database > Connection String,
#     JDBC form; use the "Session" connection string for a long-lived pool) --
DB_PROVIDER=supabase
DB_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=postgres
DB_PASSWORD=<supabase-db-password>

# --- Self-hosted (future). Point at your own Postgres. -----------------------
# DB_PROVIDER=self-hosted
# DB_URL=jdbc:postgresql://<host>:5432/<db>?sslmode=require
# DB_USERNAME=<user>
# DB_PASSWORD=<password>

# ----------------------------------------------------------------------------
# Redis — off by default. Flip to true when scaling to multiple instances.
# ----------------------------------------------------------------------------
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ----------------------------------------------------------------------------
# Auth feature flags
# ----------------------------------------------------------------------------
AUTH_TWO_FACTOR=false
AUTH_RATE_LIMIT=true
AUTH_PASSWORD_RESET=true
AUTH_SESSION_ROTATION=true

# ----------------------------------------------------------------------------
# Outbox relay — event bus on/off. Turn off for data-import migrations.
# ----------------------------------------------------------------------------
OUTBOX_RELAY=true

# ----------------------------------------------------------------------------
# Sentry — off by default. When enabled, DSN must be set. Uncaught exceptions
# and Logback ERROR events ship to Sentry with the request_id tag.
# ----------------------------------------------------------------------------
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=dev
SENTRY_RELEASE=self-backend@0.1.0-SNAPSHOT
SENTRY_TRACES_SAMPLE_RATE=0.1

# ----------------------------------------------------------------------------
# JWT (must be >= 32 bytes / 256 bits)
# ----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-32-byte-random-secret-value-please
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P30D

# ----------------------------------------------------------------------------
# Mail (mailhog for local dev)
# ----------------------------------------------------------------------------
MAIL_PROVIDER=mailhog
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@edss.local

# ----------------------------------------------------------------------------
# Seed admin (dev only)
# ----------------------------------------------------------------------------
ADMIN_EMAIL=admin@edss.local
ADMIN_PASSWORD=Admin@Password123!

# ----------------------------------------------------------------------------
# CORS
# ----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3000

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
SERVER_PORT=8080
