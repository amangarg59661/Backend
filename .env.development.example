# ============================================================================
# Development environment. Copy to .env and edit.
#   cp .env.development.example .env
#
# Loose security defaults live in application-dev.yml — this file only wires
# secrets and provider endpoints.
# ============================================================================

SPRING_PROFILES_ACTIVE=dev

# --- Database (local Docker Postgres on 5433) -------------------------------
DB_PROVIDER=self-hosted
DB_URL=jdbc:postgresql://localhost:5433/edss
DB_USERNAME=edss
DB_PASSWORD=edss

# --- Or Supabase dev project (uncomment) ------------------------------------
# DB_PROVIDER=supabase
# DB_URL=jdbc:postgresql://db.<dev-project-ref>.supabase.co:5432/postgres?sslmode=require
# DB_USERNAME=postgres
# DB_PASSWORD=<supabase-dev-db-password>

# --- Redis (off in dev; in-memory stores) -----------------------------------
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Mail (Mailhog on docker-compose) ---------------------------------------
MAIL_PROVIDER=mailhog
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@edss.local

# --- Sentry (off by default; flip to true with a dev-project DSN) -----------
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=self-backend@0.1.0-SNAPSHOT
SENTRY_TRACES_SAMPLE_RATE=1.0

# --- JWT (must be >= 32 bytes / 256 bits) -----------------------------------
JWT_SECRET=change-me-to-a-32-byte-random-secret-value-please
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P30D

# --- Secret encryption (base64 32 bytes) used for TOTP + trusted device -----
# Generate: openssl rand -base64 32
SECRET_ENCRYPTION_KEY=Zm9vYmFyYmF6cXV4Zm9vYmFyYmF6cXV4Zm9vYmFyYmE=

# --- Auth self-service extras -----------------------------------------------
AUTH_TWO_FACTOR_ENROLLMENT=true
AUTH_REMEMBER_DEVICE_DAYS=30

# --- File storage backend (supabase | s3) -----------------------------------
FILE_BACKEND=supabase

# Supabase Storage credentials (only read when FILE_BACKEND=supabase)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_PREFIX=edss-dev

# AWS S3 credentials (only read when FILE_BACKEND=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# --- Payments (all off in dev; flip individually to test with sandbox keys) --
PAYMENTS_STRIPE_ENABLED=false
PAYMENTS_RAZORPAY_ENABLED=false
PAYMENTS_MANUAL_ENABLED=true

# Stripe test-mode credentials (only read when PAYMENTS_STRIPE_ENABLED=true)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Razorpay test-mode credentials (only read when PAYMENTS_RAZORPAY_ENABLED=true)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Notification channels --------------------------------------------------
NOTIFICATIONS_EMAIL=true
NOTIFICATIONS_IN_APP=true
NOTIFICATIONS_WHATSAPP=false
NOTIFICATIONS_SMS=false

# --- Calendar + messaging ---------------------------------------------------
CALENDAR_PROVIDER=manual
GOOGLE_CALENDAR_SYNC=false
WHATSAPP_ENABLED=false

# Twilio WhatsApp Business (only read when WHATSAPP_ENABLED=true)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=+14155238886

# Cal.com / Calendly (only read when CALENDAR_PROVIDER matches)
CALCOM_API_KEY=
CALCOM_WEBHOOK_SECRET=
CALENDLY_API_KEY=
CALENDLY_WEBHOOK_SECRET=

# Google Calendar OAuth (only read when GOOGLE_CALENDAR_SYNC=true)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/v1/integrations/google/callback

# --- Seed admin -------------------------------------------------------------
ADMIN_EMAIL=admin@edss.local
ADMIN_PASSWORD=Admin@Password123!

# --- CORS (application-dev.yml already opens all localhost origins) ---------
CORS_ALLOWED_ORIGINS=http://localhost:3001

# --- Server -----------------------------------------------------------------
SERVER_PORT=8080
