# ============================================================================
# Development environment. Copy to .env and edit.
#   cp .env.development.example .env
#
# Loose security defaults live in application-dev.yml — this file only wires
# secrets and provider endpoints.
# ============================================================================

SPRING_PROFILES_ACTIVE=dev

# --- Database (local Docker Postgres on 5433) -------------------------------
DB_PROVIDER=self-hosted
DB_URL=jdbc:postgresql://localhost:5433/edss
DB_USERNAME=edss
DB_PASSWORD=edss

# --- Or Supabase dev project (uncomment) ------------------------------------
# DB_PROVIDER=supabase
# DB_URL=jdbc:postgresql://db.<dev-project-ref>.supabase.co:5432/postgres?sslmode=require
# DB_USERNAME=postgres
# DB_PASSWORD=<supabase-dev-db-password>

# --- Redis (off in dev; in-memory stores) -----------------------------------
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Mail (Mailhog on docker-compose) ---------------------------------------
MAIL_PROVIDER=mailhog
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@edss.local

# --- Sentry (off by default; flip to true with a dev-project DSN) -----------
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=self-backend@0.1.0-SNAPSHOT
SENTRY_TRACES_SAMPLE_RATE=1.0

# --- JWT (must be >= 32 bytes / 256 bits) -----------------------------------
JWT_SECRET=change-me-to-a-32-byte-random-secret-value-please
JWT_ACCESS_TTL=PT15M
JWT_REFRESH_TTL=P30D

# --- Seed admin -------------------------------------------------------------
ADMIN_EMAIL=admin@edss.local
ADMIN_PASSWORD=Admin@Password123!

# --- CORS (application-dev.yml already opens all localhost origins) ---------
CORS_ALLOWED_ORIGINS=http://localhost:3001

# --- Server -----------------------------------------------------------------
SERVER_PORT=8080
